# Bu dosyayı .env olarak kopyalayıp gerçek değerlerle doldurun.
# .env dosyası git'e girmez (.gitignore).
#
#   cp .env.example .env

# ── PostgreSQL (docker-compose'un db servisi bu değerlerle başlar) ──
POSTGRES_DB=kurbandb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Backend'in veritabanına bağlanacağı URL (docker-compose içinde servis adı "db")
DB_URL=jdbc:postgresql://db:5432/kurbandb
DB_USERNAME=postgres
DB_PASSWORD=change-me-strong-password

# ── JWT ───────────────────────────────────────────
# Üretmek için: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION_MINUTES=720

# ── İlk admin hesabı (sadece staff_user tablosu boşsa, ilk açılışta oluşturulur) ──
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-strong-password

# ── SMS (Netgsm) ───────────────────────────────────
# Netgsm hesabınız olana kadar SMS_ENABLED=false kalsın (loglara yazılır, gerçek SMS gitmez).
SMS_ENABLED=false
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=KURBAN

# ── Sıra ayarları ─────────────────────────────────
NOSHOW_TIMEOUT_MINUTES=15

# ── CORS (frontend'in çalıştığı origin'ler, virgülle ayrılmış) ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend build-time ───────────────────────────
VITE_API_BASE=/api

# ── Domain (Caddy otomatik HTTPS için, docker-compose) ──
DOMAIN=localhost
